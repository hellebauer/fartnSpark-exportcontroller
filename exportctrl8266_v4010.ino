var heapChartInst = null;
async function loadHeap(){
  try{
    var r=await fetch('/api/heap');
    var d=await r.json();
    if(!d.data||d.data.length===0) return;
    var data=d.data;
    var cur=(d.current/10).toFixed(1);
    var minVal=Math.min(...data); var minIdx=data.lastIndexOf(minVal);
    var maxVal=Math.max(...data); var maxIdx=data.lastIndexOf(maxVal);
    var hoursAgo=function(idx){return data.length-1-idx;};
    var fmtAge=function(h){if(h<1)return'just now';if(h<24)return h+'h ago';return Math.round(h/24)+'d ago';};
    document.getElementById('hm-current').textContent=cur+' KB';
    document.getElementById('hm-min').textContent=(minVal/10).toFixed(1)+' KB';
    document.getElementById('hm-min-when').textContent=fmtAge(hoursAgo(minIdx));
    document.getElementById('hm-max').textContent=(maxVal/10).toFixed(1)+' KB';
    document.getElementById('hm-max-when').textContent=fmtAge(hoursAgo(maxIdx));
    var oldestH=data.length-1;
    document.getElementById('hm-oldest').textContent=fmtAge(oldestH);
    var isDark=matchMedia('(prefers-color-scheme:dark)').matches;
    var lineColor='#1d9e75';
    var fillColor=isDark?'rgba(29,158,117,.15)':'rgba(29,158,117,.1)';
    var gridColor=isDark?'rgba(255,255,255,.06)':'rgba(0,0,0,.06)';
    var chartData=data.map(function(v){return v/10;});
    if(heapChartInst){heapChartInst.destroy();}
    heapChartInst=new Chart(document.getElementById('heapChart'),{
      type:'line',
      data:{labels:chartData.map(function(_,i){return i;}),datasets:[{data:chartData,borderColor:lineColor,borderWidth:1.5,backgroundColor:fillColor,fill:true,pointRadius:0,tension:0.3}]},
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:function(c){return c.parsed.y.toFixed(1)+' KB';},title:function(c){return(data.length-c[0].dataIndex)+'h ago';}}}},
        scales:{x:{display:false},y:{display:true,min:10,max:50,grid:{color:gridColor},ticks:{font:{size:10},color:isDark?'rgba(255,255,255,.4)':'rgba(0,0,0,.35)',callback:function(v){return v+' KB';},maxTicksLimit:4}}}}
    });
  }catch(e){console.log('heap fetch err',e);}
}
var lastUptime=-1;
var bootTime=null;
async function loadLog(){
  try{
    var sr=await fetch('/api/status');
    var sd=await sr.json();
    var uptime=sd.uptime||0;
    // Detect reboot: uptime went backwards
    if(bootTime===null||uptime<lastUptime) bootTime=new Date(Date.now()-uptime*1000);
    lastUptime=uptime;
    var t=await (await fetch('/api/log')).text();
    var lines=(t||'').split('\n');
    var out=lines.map(function(line){
      var m=line.match(/^\[(\d+)s\](.*)/);
      if(!m) return line;
      var d=new Date(bootTime.getTime()+parseInt(m[1])*1000);
      var ts=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0')+
             ' '+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0')+':'+String(d.getSeconds()).padStart(2,'0');
      return ts+m[2];
    }).join('\n');
    var b=document.getElementById('logbox');
    b.textContent=out||'(empty)';
    b.scrollTop=b.scrollHeight;
  }catch(e){}
}
renderPlugs(null);
