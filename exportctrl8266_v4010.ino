// ── Logging ──────────────────────────────────────────────
void addLog(const String& msg) {
  String line = "[" + String(millis()/1000) + "s] " + msg + "\n";
  logBuffer += line;
  if (logBuffer.length() > LOG_MAX)
    logBuffer = logBuffer.substring(logBuffer.length() - LOG_MAX);
  Serial.print(line);
}

