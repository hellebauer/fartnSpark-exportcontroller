}

// ── Switch Queue ──────────────────────────────────────────────
void queueSwitch(int idx, bool on) {
  if (idx < 0 || idx >= MAX_PLUGS) return;
  switchDesired[idx] = on ? 1 : -1;
  if (cfg.plugs[idx].desiredState != on || cfg.plugs[idx].desiredSetMs == 0) {
    cfg.plugs[idx].desiredState = on;
    cfg.plugs[idx].desiredSetMs = millis();
    cfg.plugs[idx].fault = false;   // give it a fresh chance to reach the new state
  }
}

bool shellySet(int idx, bool on) {
  if (!cfg.plugs[idx].enabled || !cfg.plugs[idx].ip[0]) return false;
  queueSwitch(idx, on);
  return true;
}

// ── Async Switch State Machine ────────────────────────────────
enum SwitchState { SS_IDLE, SS_CONNECTING, SS_SENDING, SS_RECEIVING };
static SwitchState   swState   = SS_IDLE;
static WiFiClient    swClient;
static int           swIdx     = -1;
static bool          swOn      = false;
static unsigned long swStateMs = 0;
static char          swBuf[512];
static int           swBufLen  = 0;

void asyncSwitchTick() {
  if (WiFi.status() != WL_CONNECTED) return;
  switch (swState) {
    case SS_IDLE: {
      for (int i = 0; i < MAX_PLUGS; i++) {
        if (!switchDesired[i]) continue;
        if (!cfg.plugs[i].enabled || !cfg.plugs[i].ip[0]) { switchDesired[i]=0; continue; }
        bool wantOn = (switchDesired[i] == 1);
        if (cfg.plugs[i].lastState == wantOn) { switchDesired[i]=0; continue; }
        // Skip offline plugs - poller will recover when plug comes back
        if (!cfg.plugs[i].online && cfg.plugs[i].lastPollMs > 0) { switchDesired[i]=0; continue; }
        unsigned long minMs = wantOn ? (unsigned long)cfg.minToggleSec*1000UL
                                     : (unsigned long)cfg.minToggleOffSec*1000UL;
        if (cfg.plugs[i].lastToggleMs > 0 && minMs > 0 && millis()-cfg.plugs[i].lastToggleMs < minMs) {
          addLog("Plug "+String(i+1)+(wantOn?" skip ON":" skip OFF")+" (too soon)"); switchDesired[i]=0; continue;
        }
        swIdx = i; swOn = wantOn; switchDesired[i] = 0;
        swClient.stop(); swClient.connect(cfg.plugs[swIdx].ip, 80);
        swStateMs = millis(); swState = SS_CONNECTING;
        Serial.println("[switch] plug "+String(swIdx+1)+(swOn?" ON":" OFF"));
        break;
      }
      break;
    }
    case SS_CONNECTING: {
      if (swClient.connected()) { swState = SS_SENDING; }
      else if (millis()-swStateMs > 1000) {
        addLog("Plug "+String(swIdx+1)+" connect timeout");
        cfg.plugs[swIdx].online = false; swClient.stop(); swState = SS_IDLE;
      }
      break;
    }
    case SS_SENDING: {
      String path;
      if (cfg.plugs[swIdx].gen == SHELLY_GEN2)
        path = "/rpc/Switch.Set?id=0&on=" + String(swOn?"true":"false");
      else
        path = "/relay/0?turn=" + String(swOn?"on":"off");
      swClient.print("GET "+path+" HTTP/1.1\r\nHost: "+String(cfg.plugs[swIdx].ip)+"\r\nConnection: close\r\n\r\n");
      swBufLen = 0; swBuf[0] = 0; swStateMs = millis(); swState = SS_RECEIVING;
      break;
    }
    case SS_RECEIVING: {
      while (swClient.available() && swBufLen < (int)sizeof(swBuf)-1)
        swBuf[swBufLen++] = swClient.read();
      swBuf[swBufLen] = 0;
      if (!swClient.connected()) {
        swClient.stop();
        bool ok = strstr(swBuf, "200 OK") != nullptr;
        cfg.plugs[swIdx].online = ok;
        cfg.plugs[swIdx].lastState = swOn;
        if (ok) cfg.plugs[swIdx].lastToggleMs = millis();
        if (ok) plugCycles[swIdx]++;   // raw ops; displayed as /2 (each ON+OFF pair = 1 cycle)
        addLog("Plug "+String(swIdx+1)+" ["+String(cfg.plugs[swIdx].name)+"] "+(swOn?"ON":"OFF")+(ok?" OK":" FAILED"));
        swState = SS_IDLE;
      } else if (millis()-swStateMs > 2000) {
        addLog("Plug "+String(swIdx+1)+" timeout"); cfg.plugs[swIdx].online=false;
        swClient.stop(); swState = SS_IDLE;
      }
      break;
    }
  }
}

// ── Async Poller State Machine ───────────────────────────────
enum PollState { PS_IDLE, PS_CONNECTING, PS_SENDING, PS_RECEIVING, PS_PARSING };
static PollState     pollState      = PS_IDLE;
static WiFiClient    pollClient;
static int           pollIdx        = 0;
static char          pollBuf[1200];
static int           pollBufLen     = 0;
static unsigned long pollStateMs    = 0;
static unsigned long lastPollStartMs = 0;

void asyncPollerTick() {
  if (WiFi.status() != WL_CONNECTED) return;
  switch (pollState) {
    case PS_IDLE: {
      if (millis()-lastPollStartMs < POLL_INTERVAL_MS) return;
      int checked = 0;
      while (checked < MAX_PLUGS) {
        pollIdx = (pollIdx+1) % MAX_PLUGS; checked++;
        if (cfg.plugs[pollIdx].enabled && cfg.plugs[pollIdx].ip[0]) break;
      }
      if (!cfg.plugs[pollIdx].enabled || !cfg.plugs[pollIdx].ip[0]) { lastPollStartMs=millis(); return; }
      if (ESP.getFreeHeap() < 8000) { lastPollStartMs=millis(); return; }
      pollClient.stop(); pollBufLen=0; pollBuf[0]=0;
      pollStateMs = millis(); lastPollStartMs = millis();
      pollClient.connect(cfg.plugs[pollIdx].ip, 80);
      pollState = PS_CONNECTING;
      break;
    }
    case PS_CONNECTING: {
      if (pollClient.connected()) { Serial.println("[poll] connected plug "+String(pollIdx+1)); pollState = PS_SENDING; }
      else if (millis()-pollStateMs > 1000) {
        Serial.println("[poll] connect timeout plug "+String(pollIdx+1));
        cfg.plugs[pollIdx].online = false; pollClient.stop(); pollState = PS_IDLE;
      }
      break;
    }
    case PS_SENDING: {
      String path = (cfg.plugs[pollIdx].gen==SHELLY_GEN2) ? "/rpc/Switch.GetStatus?id=0" : "/status";
      pollClient.print("GET "+path+" HTTP/1.1\r\nHost: "+String(cfg.plugs[pollIdx].ip)+"\r\nConnection: close\r\n\r\n");
      pollBufLen=0; pollBuf[0]=0; pollStateMs=millis(); pollState=PS_RECEIVING;
      break;
    }
    case PS_RECEIVING: {
      while (pollClient.available() && pollBufLen < (int)sizeof(pollBuf)-1)
        pollBuf[pollBufLen++] = pollClient.read();
      pollBuf[pollBufLen] = 0;
      if (!pollClient.connected()) { pollState = PS_PARSING; }
      else if (millis()-pollStateMs > 2000) {
        cfg.plugs[pollIdx].online=false; pollClient.stop(); pollState=PS_IDLE;
      }
      break;
    }
    case PS_PARSING: {
      pollClient.stop();
      char* sep = strstr(pollBuf, "\r\n\r\n");
      if (!sep) { Serial.println("[poll] no body, buf="+String(pollBufLen)+"B: "+String(pollBuf).substring(0,80)); cfg.plugs[pollIdx].online=false; pollState=PS_IDLE; return; }
      char* body = sep + 4;
      // Skip chunked transfer encoding if present (hex size on first line)
      // Chunked format: "3f2\r\n{json}\r\n0\r\n"
      char* bodyStart = body;
      // If first char is hex digit, skip the chunk size line
      if ((*body >= '0' && *body <= '9') || (*body >= 'a' && *body <= 'f') || (*body >= 'A' && *body <= 'F')) {
        char* chunkEnd = strstr(body, "\r\n");
        if (chunkEnd) bodyStart = chunkEnd + 2;
      }
      Serial.println("[poll] body[0]="+String((int)bodyStart[0])+" len="+String(strlen(bodyStart))+" plug="+String(pollIdx+1));
      if (strlen(bodyStart) > 2000) { Serial.println("[poll] body too large"); cfg.plugs[pollIdx].online=false; pollState=PS_IDLE; return; }
      Serial.println("[poll] heap before parse: "+String(ESP.getFreeHeap()));
      JsonDocument doc;
      DeserializationError err = deserializeJson(doc, bodyStart);
      if (err) { Serial.println("[poll] JSON err: "+String(err.c_str())); cfg.plugs[pollIdx].online=false; pollState=PS_IDLE; return; }
      cfg.plugs[pollIdx].online = true;
      if (cfg.plugs[pollIdx].gen == SHELLY_GEN2) {
        cfg.plugs[pollIdx].power     = fabsf(doc["apower"] | 0.0f);
        cfg.plugs[pollIdx].rssi      = 0;  // not in Switch.GetStatus
        cfg.plugs[pollIdx].lastState = doc["output"] | false;
      } else {
        cfg.plugs[pollIdx].power     = fabsf(doc["meters"][0]["power"] | 0.0f);
        cfg.plugs[pollIdx].rssi      = doc["wifi_sta"]["rssi"] | 0;
        cfg.plugs[pollIdx].lastState = doc["relays"][0]["ison"] | false;
      }
      cfg.plugs[pollIdx].lastPollMs = millis();
      Serial.println("[poll] Plug "+String(pollIdx+1)+" pwr="+String(cfg.plugs[pollIdx].power,1)+"W rssi="+String(cfg.plugs[pollIdx].rssi)+" on="+String(cfg.plugs[pollIdx].lastState));
      pollState = PS_IDLE;
      break;
    }
  }
}

// ── Fleet Control ──────────────────────────────────────────────
int countActivePLugs() {
  int n = 0;
  for (int i = 0; i < MAX_PLUGS; i++)
    if (cfg.plugs[i].enabled && cfg.plugs[i].ip[0] && cfg.plugs[i].lastState
        && (millis()-cfg.plugs[i].lastPollMs < 30000)) n++;
  return n;
}

float avgPlugPower() {
  float total = 0; int n = 0;
  for (int i = 0; i < MAX_PLUGS; i++)
    if (cfg.plugs[i].enabled && cfg.plugs[i].ip[0] && cfg.plugs[i].lastState && cfg.plugs[i].power > 5.0f)
      { total += cfg.plugs[i].power; n++; }
  return n > 0 ? total/n : 80.0f;
}

// Effective per-plug power estimate used for switching decisions.
// Priority (v4.001): current measured power (if plausible) > user nominalW (fallback
// when a Shelly reports 0W / no reading) > fleet average. Measurement-first keeps
// best-fit accurate under partial load; nominalW is the safety net, not the default.
float plugEstW(int i, float fleetAvg) {
  if (cfg.plugs[i].power    > 5.0f) return cfg.plugs[i].power;
  if (cfg.plugs[i].nominalW > 5.0f) return cfg.plugs[i].nominalW;
  return fleetAvg;
}

// Moving average of grid power over avgWindowSec (samples arrive ~every MQTT msg).
float avgGridPower() {
  if (gridPowerBufCount == 0) return gridPower;
  int cap = cfg.avgWindowSec / 5; if (cap < 1) cap = 1; if (cap > 60) cap = 60;
  int count = min(gridPowerBufCount, cap);
  float sum = 0;
  for (int i = 0; i < count; i++) {
    int idx = (gridPowerBufIdx - 1 - i + 60) % 60;
    sum += gridPowerBuf[idx];
  }
  return sum / count;
}

// Soll/Ist fault detection: flag plugs that haven't reached commanded state in time.
void checkPlugFaults() {
  unsigned long to = (unsigned long)cfg.faultTimeoutSec * 1000UL;
  if (to == 0) return;
  for (int i = 0; i < MAX_PLUGS; i++) {
    if (!cfg.plugs[i].enabled || !cfg.plugs[i].ip[0]) { cfg.plugs[i].fault = false; continue; }
    if (cfg.plugs[i].desiredSetMs == 0) continue;          // never commanded yet
    if (cfg.plugs[i].lastPollMs == 0) continue;            // no confirmation yet
    if (cfg.plugs[i].lastState == cfg.plugs[i].desiredState) { cfg.plugs[i].fault = false; continue; }
    if (millis() - cfg.plugs[i].desiredSetMs > to && !cfg.plugs[i].fault) {
      cfg.plugs[i].fault = true;
      addLog("FAULT S"+String(i+1)+" ["+String(cfg.plugs[i].name)+"] commanded "
             +(cfg.plugs[i].desiredState?"ON":"OFF")+" but reads "
             +(cfg.plugs[i].lastState?"ON":"OFF"));
    }
  }
}

void runControl() {
  if (WiFi.status() != WL_CONNECTED) return;

  // MQTT stale -> failsafe (0=all OFF, 1=all ON, 2=S1 only)
  if (cfg.mqttHost[0] && mqttLastMsgMs > 0 && millis()-mqttLastMsgMs > 60000) {
    if (!mqttStale) {
      mqttStale = true;
      if (cfg.mqttFailsafeMode == 1) {
        addLog(F("MQTT stale >60s - all ON (failsafe)"));
        for (int i=0; i<MAX_PLUGS; i++)
          if (cfg.plugs[i].enabled && cfg.plugs[i].ip[0]) queueSwitch(i, true);
      } else if (cfg.mqttFailsafeMode == 2) {
        addLog(F("MQTT stale >60s - S1 ON, rest OFF (failsafe)"));
        for (int i=0; i<MAX_PLUGS; i++)
          if (cfg.plugs[i].enabled && cfg.plugs[i].ip[0]) queueSwitch(i, i==0);
      } else {
        addLog(F("MQTT stale >60s - all OFF (failsafe)"));
        for (int i=0; i<MAX_PLUGS; i++)
          if (cfg.plugs[i].enabled && cfg.plugs[i].ip[0]) queueSwitch(i, false);
      }
    }
    return;
  }

  checkPlugFaults();

  float smoothPower = avgGridPower();
  smoothPowerCache  = smoothPower;

  // Dynamic threshold from 15-min export energy budget (configurable).
  float dynamicThreshold = cfg.exportThreshold;
  unsigned long slotLenMs = (unsigned long)cfg.slotMinutes * 60000UL;
  if (slotStartMs > 0 && slotLenMs > 0) {
    float timeLeftSec = (slotLenMs - (millis() - slotStartMs)) / 1000.0f;
    if (timeLeftSec < 10.0f) timeLeftSec = 10.0f;
    float remainingBudget = cfg.slotBudgetWh - slotExportWh;
    if (remainingBudget < 0) remainingBudget = 0;
    float budgetThreshold = remainingBudget / timeLeftSec * 3600.0f;
    dynamicThreshold = min(cfg.exportThreshold, budgetThreshold);
  }
  dynThresholdCache = dynamicThreshold;

  Serial.println("[ctrl] gp="+String(gridPower,1)+" sm="+String(smoothPower,1)
                 +" thr="+String(dynamicThreshold,1)+" active="+String(countActivePLugs()));

  float avg    = avgPlugPower();
  int   active = countActivePLugs();
  float excess = smoothPower - dynamicThreshold;

  if (excess > 0 && active > 0) {
    // v4.002 post-OFF lockout: after shedding, wait until the moving average reflects
    // the action before shedding again (prevents overshoot from average lag).
    if (lastOffMs > 0 && (millis() - lastOffMs) < (unsigned long)cfg.offLockoutSec * 1000UL) {
      Serial.println("[ctrl] OFF locked ("+String((millis()-lastOffMs)/1000)+"s/"+String(cfg.offLockoutSec)+"s)");
    } else {
      // "Keep one WR" rule: among ON plugs eligible to stay alone (nomW>0 and nomW<=threshold),
      // protect the one with the highest current power (handles ramp: keeps the running one,
      // not a freshly switched ramping one). It is tabu from shedding.
      int keepIdx = -1; float keepPower = -1.0f;
      for (int i = 0; i < MAX_PLUGS; i++) {
        if (!cfg.plugs[i].enabled || !cfg.plugs[i].ip[0] || !cfg.plugs[i].lastState) continue;
        if (cfg.plugs[i].fault) continue;                               // faulted: skip
        if (cfg.plugs[i].nominalW <= 5.0f) continue;                    // unknown nomW: cannot protect
        if (cfg.plugs[i].nominalW > dynamicThreshold) continue;         // alone breaches: not protectable
        if (cfg.plugs[i].power > keepPower) { keepPower = cfg.plugs[i].power; keepIdx = i; }
      }
      // Best-fit OFF: pick plug whose power is closest to excess from above; else largest.
      int bestIdx = -1; float bestDiff = 1e9f;
      float bestLarge = -1; int bestLargeIdx = -1;
      for (int i = 0; i < MAX_PLUGS; i++) {
        if (!cfg.plugs[i].enabled || !cfg.plugs[i].ip[0] || !cfg.plugs[i].lastState) continue;
        if (cfg.plugs[i].fault) continue;                               // faulted: skip
        if (i == keepIdx) continue;   // protected WR: never shed
        float pw = plugEstW(i, avg);
        if (pw >= excess) { float diff = pw - excess; if (diff < bestDiff) { bestDiff = diff; bestIdx = i; } }
        if (pw > bestLarge) { bestLarge = pw; bestLargeIdx = i; }
      }
      if (bestIdx == -1) bestIdx = bestLargeIdx;
      if (bestIdx >= 0) {
        addLog("Best-fit OFF S"+String(bestIdx+1)+" ("+String(plugEstW(bestIdx,avg),0)+"W excess="+String(excess,1)
               +"W keep=S"+String(keepIdx+1)+")");
        shellySet(bestIdx, false);
        lastOffMs = millis();
      }
    }
  } else if (smoothPower < cfg.onThreshold) {
    // smoothPower is below onThreshold (default 0W = importing): add capacity.
    if (lastOnMs > 0 && (millis() - lastOnMs) < (unsigned long)cfg.onLockoutSec * 1000UL) {
      Serial.println("[ctrl] ON locked ("+String((millis()-lastOnMs)/1000)+"s/"+String(cfg.onLockoutSec)+"s)");
      return;
    }
    float headroom = dynamicThreshold - smoothPower;
    int bestOnIdx = -1; float bestOnDiff = 1e9f;
    for (int i = 0; i < MAX_PLUGS; i++) {
      if (!cfg.plugs[i].enabled || !cfg.plugs[i].ip[0] || cfg.plugs[i].lastState) continue;
      if (cfg.plugs[i].fault) continue;                               // faulted: skip
      float pw = plugEstW(i, avg);
      if (pw <= headroom) { float diff = headroom - pw; if (diff < bestOnDiff) { bestOnDiff = diff; bestOnIdx = i; } }
    }
    if (bestOnIdx >= 0) {
      addLog("Best-fit ON S"+String(bestOnIdx+1)+" ("+String(plugEstW(bestOnIdx,avg),0)+"W headroom="+String(headroom,1)+"W thr="+String(cfg.onThreshold,0)+"W)");
      shellySet(bestOnIdx, true);
      lastOnMs = millis();
    }
  }
}

// ── MQTT ────────────────────────────────────────────────
void mqttCallback(char* topic, byte* payload, unsigned int length) {
  JsonDocument doc;
  if (deserializeJson(doc, (const char*)payload, length)) return;
  float val = 0; bool found = false;
  if (!doc["SML"].isNull()) {
    JsonObject sml = doc["SML"];
    if (!sml[cfg.mqttPowerKey].isNull()) { val = sml[cfg.mqttPowerKey].as<float>(); found = true; }
    if (!found) {
      const char* keys[] = {"grid_power","Power","power","P_total","Wirkleistung","16.7.0","1.7.0",nullptr};
      for (int k = 0; keys[k] && !found; k++)
        if (!sml[keys[k]].isNull()) { val = sml[keys[k]].as<float>(); found = true; }
    }
  }
  if (!found && !doc["ENERGY"].isNull()) { val = doc["ENERGY"]["Power"].as<float>(); found = true; }
  if (!found && !doc[cfg.mqttPowerKey].isNull()) { val = doc[cfg.mqttPowerKey].as<float>(); found = true; }
  if (found) {
    gridPower = val; mqttLastMsgMs = millis(); mqttStale = false;
    // Moving-average buffer
    gridPowerBuf[gridPowerBufIdx] = val;
    gridPowerBufIdx = (gridPowerBufIdx + 1) % 60;
    if (gridPowerBufCount < 60) gridPowerBufCount++;
    // Energy budget integration (only count export, val > 0)
    if (slotStartMs == 0) slotStartMs = millis();
    if (lastMqttMs > 0 && val > 0) {
      float elapsedSec = (millis() - lastMqttMs) / 1000.0f;
      slotExportWh += val * elapsedSec / 3600.0f;
    }
    lastMqttMs = millis();
    unsigned long slotLenMs = (unsigned long)cfg.slotMinutes * 60000UL;
    if (slotStartMs > 0 && slotLenMs > 0 && millis() - slotStartMs >= slotLenMs) {
      addLog("Slot reset. Exported: "+String(slotExportWh,1)+"Wh");
      slotExportWh = 0; slotStartMs = millis();
    }
  }
  else addLog(F("MQTT: no power key found"));
}

void mqttReconnect() {
  if (!cfg.mqttHost[0] || mqtt.connected()) return;
  mqtt.setSocketTimeout(1);
  mqtt.setServer(cfg.mqttHost, cfg.mqttPort);
  mqtt.setCallback(mqttCallback);
  String id = "FartNSpark-" + String(ESP.getChipId(), HEX);
  bool ok = strlen(cfg.mqttUser) > 0
    ? mqtt.connect(id.c_str(), cfg.mqttUser, cfg.mqttPass)
    : mqtt.connect(id.c_str());
  if (ok) { mqtt.subscribe(cfg.mqttTopic); addLog("MQTT OK -> "+String(cfg.mqttTopic)); }
  else addLog("MQTT fail rc="+String(mqtt.state()));
}

// ── Status JSON ──────────────────────────────────────────────
String buildStatus() {
  JsonDocument doc;
  doc["gridPower"] = gridPower;
  doc["smoothPower"] = smoothPowerCache;
  doc["avgWin"]      = cfg.avgWindowSec;
  doc["dynThresh"] = dynThresholdCache;
  doc["slotWh"]    = slotExportWh;
  doc["expThresh"] = cfg.exportThreshold;
  doc["onThresh"]  = cfg.onThreshold;
  doc["ctrlInterval"] = cfg.ctrlIntervalSec;
  doc["mqttOk"]    = mqtt.connected();
  doc["mqttStale"] = mqttStale;
  doc["mqttAge"]   = mqttLastMsgMs > 0 ? (long)((millis()-mqttLastMsgMs)/1000) : -1;
  doc["uptime"]    = millis()/1000;
  doc["freeHeap"]  = ESP.getFreeHeap();
  doc["version"]   = FW_VERSION;
  doc["ip"]        = WiFi.localIP().toString();
  doc["rssi"]      = WiFi.RSSI();
  doc["ssid"]      = WiFi.SSID();
  JsonArray arr = doc["plugs"].to<JsonArray>();
  for (int i = 0; i < MAX_PLUGS; i++) {
    JsonObject p = arr.add<JsonObject>();
    p["idx"]=i+1; p["ip"]=cfg.plugs[i].ip; p["name"]=cfg.plugs[i].name;
    p["enabled"]=cfg.plugs[i].enabled; p["on"]=cfg.plugs[i].lastState;
    p["online"]=cfg.plugs[i].online; p["gen"]=cfg.plugs[i].gen;
    p["power"]=cfg.plugs[i].power; p["rssi"]=cfg.plugs[i].rssi;
    p["fault"]=cfg.plugs[i].fault; p["nomW"]=cfg.plugs[i].nominalW;
    p["cycles"] = plugCycles[i] / 2.0f;   // half-cycles: each ON or OFF = 0.5
    unsigned long upSec = millis()/1000;
    if (plugCycles[i] > 0 && upSec > 0) {
      float fullCycles = plugCycles[i] / 2.0f;
      float ratePerHour = fullCycles / ((float)upSec / 3600.0f);
      p["lifeYrs"] = (ratePerHour > 0) ? String(cfg.relayRatedCycles / ratePerHour / 8760.0f, 2) : String("--");
    } else {
      p["lifeYrs"] = "--";
    }
  }
  String out; serializeJson(doc, out); return out;
}

