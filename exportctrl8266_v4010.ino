// ── Web Server ──────────────────────────────────────────────
static String postBody;

void writeHtmlToFS() {
  // Check if HTML version matches firmware version
  String storedVer = "";
  if (LittleFS.exists("/html.ver")) {
    File vf = LittleFS.open("/html.ver", "r");
    if (vf) { storedVer = vf.readString(); vf.close(); }
  }
  if (storedVer == FW_VERSION) {
    addLog(F("HTML: LittleFS up to date"));
    return;
  }
  addLog(F("HTML: writing to LittleFS..."));
  File f = LittleFS.open("/index.html", "w");
  if (!f) { addLog(F("HTML: open failed")); return; }
  const char* secs[] = {HTML_S1,HTML_S2,HTML_S3,HTML_S4,HTML_S5,HTML_S6};
  char buf[256];
  size_t totalWritten = 0;
  for (int s=0;s<6;s++) {
    size_t len=strlen_P(secs[s]), offset=0;
    while (offset<len) {
      size_t n=min((size_t)255,len-offset);
      memcpy_P(buf,secs[s]+offset,n);
      f.write((uint8_t*)buf,n);
      offset+=n; totalWritten+=n;
    }
  }
  f.close();
  addLog("HTML: wrote " + String(totalWritten) + " bytes to LittleFS");
  // Write version marker
  File vf = LittleFS.open("/html.ver", "w");
  if (vf) { vf.print(FW_VERSION); vf.close(); }
  addLog(F("HTML: written to LittleFS OK"));
}

void setupWebServer() {
  server.on("/", HTTP_GET, [](AsyncWebServerRequest* req) {
    if (LittleFS.exists("/index.html")) {
      req->send(LittleFS, "/index.html", "text/html");
    } else {
      req->send(500, "text/plain", "HTML not found - rebooting");
      delay(500); ESP.restart();
    }
  });

  server.on("/logo", HTTP_GET, [](AsyncWebServerRequest* req) {
    req->send_P(200, "image/jpeg", LOGO_JPG, LOGO_JPG_LEN);
  });

  server.on("/api/status", HTTP_GET, [](AsyncWebServerRequest* req) {
    req->send(200, "application/json", buildStatus());
  });

  server.on("/api/config", HTTP_GET, [](AsyncWebServerRequest* req) {
    JsonDocument doc;
    doc["wSSID"]=cfg.wifiSSID; doc["tz"]=cfg.timezone; doc["mHost"]=cfg.mqttHost; doc["mPort"]=cfg.mqttPort;
    doc["mUser"]=cfg.mqttUser; doc["mTopic"]=cfg.mqttTopic; doc["mPwrKey"]=cfg.mqttPowerKey;
    doc["expThr"]=cfg.exportThreshold;
    doc["apPass"]=cfg.apPassword;
    JsonArray arr = doc["plugs"].to<JsonArray>();
    for (int i=0;i<MAX_PLUGS;i++) {
      JsonObject o=arr.add<JsonObject>();
      o["ip"]=cfg.plugs[i].ip; o["name"]=cfg.plugs[i].name;
      o["enabled"]=cfg.plugs[i].enabled; o["gen"]=cfg.plugs[i].gen;
    }
    String out; serializeJson(doc,out);
    req->send(200,"application/json",out);
  });

  server.on("/api/config", HTTP_POST,
    [](AsyncWebServerRequest* req) {
      JsonDocument doc;
      if (deserializeJson(doc, postBody)) { req->send(400,"application/json",F("{\"ok\":false}")); return; }
      strlcpy(cfg.wifiSSID,    doc["wSSID"] | cfg.wifiSSID, sizeof(cfg.wifiSSID));
      strlcpy(cfg.timezone,    doc["tz"]    | cfg.timezone,  sizeof(cfg.timezone));
      if (strlen(doc["wPass"]|"")>0) strlcpy(cfg.wifiPass, doc["wPass"], sizeof(cfg.wifiPass));
      if (strlen(doc["apPass"]|"")>=8) strlcpy(cfg.apPassword, doc["apPass"], sizeof(cfg.apPassword));
      strlcpy(cfg.mqttHost,    doc["mHost"] | cfg.mqttHost,  sizeof(cfg.mqttHost));
      cfg.mqttPort           = doc["mPort"] | cfg.mqttPort;
      strlcpy(cfg.mqttUser,    doc["mUser"] | cfg.mqttUser,  sizeof(cfg.mqttUser));
      if (strlen(doc["mPass"]|"")>0) strlcpy(cfg.mqttPass, doc["mPass"], sizeof(cfg.mqttPass));
      strlcpy(cfg.mqttTopic,   doc["mTopic"]  | cfg.mqttTopic,   sizeof(cfg.mqttTopic));
      strlcpy(cfg.mqttPowerKey,doc["mPwrKey"] | cfg.mqttPowerKey,sizeof(cfg.mqttPowerKey));
      cfg.exportThreshold    = doc["expThr"]        | cfg.exportThreshold;
      cfg.ctrlIntervalSec    = doc["ctrlInterval"]  | cfg.ctrlIntervalSec;
      cfg.mqttFailsafeMode   = doc["mqttFail"]      | cfg.mqttFailsafeMode;
      cfg.minToggleSec       = doc["minToggle"]    | cfg.minToggleSec;
      cfg.minToggleOffSec    = doc["minToggleOff"] | cfg.minToggleOffSec;
      cfg.avgWindowSec       = doc["avgWin"]       | cfg.avgWindowSec;
      cfg.slotBudgetWh       = doc["slotWh"]       | cfg.slotBudgetWh;
      cfg.slotMinutes        = doc["slotMin"]      | cfg.slotMinutes;
      cfg.faultTimeoutSec    = doc["faultTo"]      | cfg.faultTimeoutSec;
      cfg.offLockoutSec      = doc["offLock"]      | cfg.offLockoutSec;
      cfg.onLockoutSec       = doc["onLock"]       | cfg.onLockoutSec;
      cfg.relayRatedCycles   = doc["relayCycles"]  | cfg.relayRatedCycles;
      cfg.onThreshold        = doc["onThresh"]     | cfg.onThreshold;
      if (cfg.avgWindowSec < 5)   cfg.avgWindowSec = 5;
      if (cfg.avgWindowSec > 300) cfg.avgWindowSec = 300;
      if (cfg.slotMinutes  < 1)   cfg.slotMinutes  = 1;
      JsonArray arr = doc["plugs"].as<JsonArray>();
      cfg.plugCount = 0;
      for (int i=0;i<MAX_PLUGS&&i<(int)arr.size();i++) {
        strlcpy(cfg.plugs[i].ip,  arr[i]["ip"]  |"",16);
        strlcpy(cfg.plugs[i].name,arr[i]["name"]|"",24);
        cfg.plugs[i].enabled = arr[i]["enabled"]|false;
        cfg.plugs[i].gen     = arr[i]["gen"]    |SHELLY_GEN2;
        cfg.plugs[i].nominalW = arr[i]["nomW"]  |0.0f;
        if (cfg.plugs[i].enabled && cfg.plugs[i].ip[0]) cfg.plugCount++;
      }
      saveConfig();
      req->send(200,"application/json",F("{\"ok\":true}"));
      delay(400); ESP.restart();
    },
    nullptr,
    [](AsyncWebServerRequest* req, uint8_t* data, size_t len, size_t index, size_t total) {
      if (index==0) { postBody=""; postBody.reserve(total); }
      postBody += String((char*)data).substring(0,len);
    }
  );

  server.on("/api/plug", HTTP_GET, [](AsyncWebServerRequest* req) {
    if (req->hasParam("idx") && req->hasParam("on")) {
      int idx = req->getParam("idx")->value().toInt() - 1;
      bool on = req->getParam("on")->value() == "1";
      if (idx >= 0 && idx < MAX_PLUGS) {
        // Bypass rate limit for manual commands
        cfg.plugs[idx].lastToggleMs = 0;
        queueSwitch(idx, on);
        Serial.println("[plug] manual plug "+String(idx+1)+(on?" ON":" OFF"));
      }
    }
    req->send(200,"application/json",F("{\"ok\":true}"));
  });

  server.on("/api/cmd", HTTP_GET, [](AsyncWebServerRequest* req) {
    if (req->hasParam("action")) {
      String a = req->getParam("action")->value();
      if (a=="on")  { pendingCmd=1;  Serial.println("[CMD] Force ON queued"); }
      if (a=="off") { pendingCmd=-1; Serial.println("[CMD] Force OFF queued"); }
    }
    req->send(200,"application/json",F("{\"ok\":true}"));
  });

  server.on("/api/heap", HTTP_GET, [](AsyncWebServerRequest* req) {
    String out = "{";
    out += "\"count\":" + String(heapLogCount) + ",";
    out += "\"current\":" + String(ESP.getFreeHeap()/100) + ",";
    out += "\"data\":[";
    // Output in chronological order (oldest first)
    int start = heapLogCount < 168 ? 0 : heapLogIdx;
    for (int i = 0; i < heapLogCount; i++) {
      int idx = (start + i) % 168;
      if (i > 0) out += ",";
      out += String(heapLog[idx]);
    }
    out += "]}";
    req->send(200,"application/json",out);
  });

  server.on("/api/log", HTTP_GET, [](AsyncWebServerRequest* req) {
    req->send(200,"text/plain",logBuffer);
  });

  server.on("/api/reset", HTTP_POST, [](AsyncWebServerRequest* req) {
    LittleFS.remove(CONFIG_FILE);
    addLog(F("Factory reset: config deleted, rebooting..."));
    req->send(200,"application/json",F("{\"ok\":true}"));
    delay(400);
    ESP.restart();
  });

  server.on("/api/reboot", HTTP_POST, [](AsyncWebServerRequest* req) {
    addLog(F("Reboot requested via web UI"));
    req->send(200,"application/json",F("{\"ok\":true}"));
    delay(400);
    ESP.restart();
  });

  server.begin();
  addLog(F("Web server started"));
}

// ── WiFi ────────────────────────────────────────────────
void startAP() {
  apMode = true;
  WiFi.mode(WIFI_AP);
  WiFi.softAP(AP_SSID, cfg.apPassword);
  Serial.println("[AP] SSID: "+String(AP_SSID)+" Password: "+String(cfg.apPassword));
  Serial.println("[AP] Send 'RESET' via Serial to clear config if locked out.");
  addLog("AP: "+String(AP_SSID)+" -> "+WiFi.softAPIP().toString());
}

bool connectWiFi() {
  if (!cfg.wifiSSID[0]) return false;
  addLog("WiFi -> "+String(cfg.wifiSSID));
  WiFi.mode(WIFI_STA);
  WiFi.begin(cfg.wifiSSID, cfg.wifiPass);
  unsigned long t = millis();
  while (WiFi.status()!=WL_CONNECTED && millis()-t<15000) { delay(300); yield(); }
  if (WiFi.status()==WL_CONNECTED) { addLog("WiFi OK -> "+WiFi.localIP().toString()); return true; }
  addLog(F("WiFi failed, starting AP")); return false;
}

// ── Setup ───────────────────────────────────────────────
void setup() {
  Serial.begin(115200); delay(300);
  addLog(F("Fart N Spark booting..."));
  if (!LittleFS.begin()) { addLog(F("LittleFS failed, formatting...")); LittleFS.format(); LittleFS.begin(); }
  loadConfig();
  if (!connectWiFi()) startAP();
  // Configure NTP with timezone
  if (!apMode) {
    configTime(cfg.timezone, "pool.ntp.org");
    Serial.println("[ntp] configured: " + String(cfg.timezone));
  }
  writeHtmlToFS();
  setupWebServer();
  if (WiFi.status()==WL_CONNECTED) mqttReconnect();
  // Log NTP sync status
  if (!apMode) {
    time_t now = time(nullptr);
    if (now > 1000000000) {
      struct tm* t = localtime(&now);
      char buf[32];
      strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", t);
      addLog("NTP OK -> " + String(buf));
    } else {
      addLog(F("NTP syncing..."));
    }
  }
  addLog("Ready. Heap: "+String(ESP.getFreeHeap())+"B  Plugs: "+String(cfg.plugCount));
}

// ── Loop ────────────────────────────────────────────────
void loop() {
  // WiFi reconnect (skip in AP mode — would disrupt connected clients)
  if (!apMode) {
    static unsigned long lastWifiRetry = 0;
    if (WiFi.status()!=WL_CONNECTED && cfg.wifiSSID[0] && millis()-lastWifiRetry>30000) {
      lastWifiRetry=millis(); WiFi.begin(cfg.wifiSSID,cfg.wifiPass);
    }
  }
  // MQTT
  if (!apMode && WiFi.status()==WL_CONNECTED && cfg.mqttHost[0]) {
    if (!mqtt.connected()) {
      static unsigned long lastRetry=0;
      if (millis()-lastRetry>60000) { lastRetry=millis(); mqttReconnect(); }
    }
    mqtt.loop();
  }
  // Control
  if (!apMode && mqttLastMsgMs > 0 && millis()-lastControlMs>(unsigned long)cfg.ctrlIntervalSec*1000UL) { lastControlMs=millis(); runControl(); }
  if (ESP.getFreeHeap() < 8000) {
    addLog(F("Low heap - rebooting"));
    delay(500);
    ESP.restart();
  }
  // Track rolling heap minimum every loop tick
  uint32_t curHeap = ESP.getFreeHeap();
  if (curHeap < heapMinThisHour) heapMinThisHour = curHeap;
  if (millis()-lastHeapSampleMs > 3600000UL) {
    lastHeapSampleMs = millis();
    heapLog[heapLogIdx] = (uint16_t)(heapMinThisHour / 100);  // store worst-case of the hour
    heapLogIdx = (heapLogIdx + 1) % 168;
    if (heapLogCount < 168) heapLogCount++;
    heapMinThisHour = 0xFFFFFFFF;  // reset for next hour
  }
  // Async state machines (skip in AP mode — no LAN, all TCP attempts would timeout)
  if (!apMode) {
    asyncSwitchTick();
    asyncPollerTick();
  }
  // Force ON/OFF command
  if (pendingCmd && WiFi.status()==WL_CONNECTED) {
    bool on = (pendingCmd==1); pendingCmd=0;
    for (int i=0;i<MAX_PLUGS;i++)
      if (cfg.plugs[i].enabled && cfg.plugs[i].ip[0]) queueSwitch(i,on);
  }
  // Serial commands
  if (Serial.available()) {
    String cmd = Serial.readStringUntil('\n'); cmd.trim();
    if (cmd == "RESET") {
      Serial.println(F("[RESET] Factory reset: deleting config.json and rebooting..."));
      LittleFS.remove(CONFIG_FILE);
      delay(200);
      ESP.restart();
    }
  }
  delay(1);
}
