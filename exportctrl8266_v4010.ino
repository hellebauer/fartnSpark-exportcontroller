  doc["avgWin"]       = cfg.avgWindowSec;
  doc["slotWh"]       = cfg.slotBudgetWh;
  doc["slotMin"]      = cfg.slotMinutes;
  doc["faultTo"]      = cfg.faultTimeoutSec;
  doc["offLock"]     = cfg.offLockoutSec;
  doc["onLock"]      = cfg.onLockoutSec;
  doc["relayCycles"] = cfg.relayRatedCycles;
  doc["onThresh"]    = cfg.onThreshold;
  JsonArray arr = doc["plugs"].to<JsonArray>();
