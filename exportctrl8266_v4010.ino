// ── Data Structures ────────────────────────────────────────
struct PlugConfig {
  char  ip[16];
  char  name[24];
  bool  enabled;
  int   gen;
  float nominalW;            // rated inverter power (W), user-entered; 0 = unknown
  bool  lastState;
  bool  online;
  float power;
  int   rssi;
  unsigned long lastToggleMs;
  unsigned long lastPollMs;
  bool  desiredState;        // last commanded state (for fault detection)
  unsigned long desiredSetMs; // millis() when desiredState last changed
  bool  fault;               // true if plug did not reach commanded state in time
};

struct AppConfig {
  char       wifiSSID[64];
  char       wifiPass[64];
  char       apPassword[32];   // AP mode password (default deye1234)
  char       timezone[64];
  char       mqttHost[64];
  int        mqttPort;
  char       mqttUser[64];
  char       mqttPass[64];
  char       mqttTopic[128];
  char       mqttPowerKey[32];
  float      exportThreshold;
  int        ctrlIntervalSec;  // default 5s
  int        mqttFailsafeMode; // 0=all OFF, 1=all ON, 2=S1 only (default)
  int        minToggleSec;
  int        minToggleOffSec;
  int        avgWindowSec;     // moving-average window (default 180s)
  float      slotBudgetWh;     // export energy budget per slot (default 200Wh)
  int        slotMinutes;      // slot length in minutes (default 15)
  int        faultTimeoutSec;  // soll/ist mismatch timeout (default 30s)
  int        offLockoutSec;    // post-OFF lockout: no further shed until elapsed (default 90s)
  int        onLockoutSec;     // post-ON lockout: no further ON command until elapsed (default 120s)
  uint32_t   relayRatedCycles; // rated relay lifetime in cycles (default 100000)
  float      onThreshold;      // switch ON only when smoothPower below this (default 0W = import only)
  int        plugCount;
  PlugConfig plugs[MAX_PLUGS];
};

